{
  "name": "lixsketch",
  "version": "5.4.18",
  "description": "Open-source infinite canvas sketching with a hand-drawn aesthetic and a Notion-like docs editor",
  "author": {
    "name": "Ayushman Bhattacharya",
    "email": "ayushman@myceli.ai",
    "url": "https://github.com/elixpo"
  },
  "license": "MIT",
  "homepage": "https://sketch.elixpo.com",
  "repository": {
    "type": "git",
    "url": "https://github.com/elixpo/elixposketch.git"
  },
  "bugs": {
    "url": "https://github.com/elixpo/elixposketch/issues"
  },
  "keywords": [
    "sketch",
    "canvas",
    "whiteboard",
    "drawing",
    "excalidraw",
    "eraser",
    "roughjs",
    "svg",
    "docs",
    "markdown",
    "editor",
    "collaboration"
  ],
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev": "concurrently -k -n next,worker -c blue,magenta \"next dev --turbo\" \"wrangler dev --port 8787 --local\"",
    "dev:next": "next dev --turbo",
    "build": "next build",
    "start": "next start",
    "worker:dev": "wrangler dev --port 8787 --local",
    "worker:deploy": "wrangler deploy",
    "db:create": "wrangler d1 create lixsketch",
    "db:migrate": "node scripts/db-migrate.mjs --remote",
    "db:migrate:local": "node scripts/db-migrate.mjs --local",
    "kv:create": "wrangler kv namespace create lixsketch"
  },
  "dependencies": {
    "@blocknote/core": "^0.47.1",
    "@blocknote/mantine": "^0.47.1",
    "@blocknote/react": "^0.47.1",
    "@cloudflare/next-on-pages": "^1.13.16",
    "@elixpo/lixeditor": "^2.6.6",
    "@elixpo/lixsketch": "workspace:*",
    "@mantine/core": "^8.3.11",
    "@mantine/hooks": "^8.3.11",
    "boxicons": "^2.1.4",
    "framer-motion": "^12.35.2",
    "fuse.js": "^7.1.0",
    "highlight.js": "^11.11.1",
    "lz-string": "^1.5.0",
    "next": "15.5.2",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "zustand": "^5.0.13"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260310.1",
    "@tailwindcss/postcss": "^4.2.1",
    "concurrently": "^10.0.3",
    "postcss": "^8.5.8",
    "raw-loader": "^4.0.2",
    "tailwindcss": "^4.2.1",
    "wrangler": "^4.72.0"
  }
}
